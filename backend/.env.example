OPENAI_API_KEY=your_key_here
ANTHROPIC_API_KEY=your_key_here
GOOGLE_API_KEY=your_key_here

# Coze Bot API (alternative to direct LLM APIs)
# Get your bot_id from: https://www.coze.cn/space/{space_id}/bot/{bot_id}
# Get your access_token from: https://www.coze.cn/open/oauth/pats
COZE_BOT_ID=your_bot_id_here
COZE_ACCESS_TOKEN=your_access_token_here
